---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { heroHighlights, keyAchievements, metrics, publishedApps, skillGroups } from '../data/profile';
import { site } from '../data/site';
import ProjectCard from '../components/ProjectCard.astro';

const featuredProjects = (await getCollection('projects', ({ data }) => data.featured)).sort(
	(a, b) => a.data.title.localeCompare(b.data.title),
);
---

<Layout title={site.title} description={site.description}>
	<main class="shell page-stack">
		<section class="hero-block">
			<div class="hero-surface">
				<p class="eyebrow">Mexico · Senior Engineering Portfolio</p>
				<p class="hero-name">{site.name}</p>
				<h1>Senior Fullstack &amp; Mobile Engineer</h1>
				<p class="lede">
					Building scalable, production-grade applications with strong focus on mobile, backend
					architecture, and real-time systems.
				</p>
				<ul class="hero-highlights">
					{heroHighlights.map((item) => <li>{item}</li>)}
				</ul>
				<div class="hero-actions">
					<a href="/projects" class="button button-primary">View Projects</a>
					<a href="/contact" class="button button-secondary">Contact Me</a>
				</div>
			</div>
			<div class="hero-aside">
				<div class="metrics-grid">
					{
						metrics.map((metric) => (
							<article class="metric-card">
								<p class="metric-value">{metric.value}</p>
								<p class="metric-label">{metric.label}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="achievement-band">
			<div class="section-head compact">
				<p class="section-kicker">Key Achievements</p>
				<h2>Selected proof points across scale, leadership, and production delivery.</h2>
			</div>
			<div class="achievements-list">
				{keyAchievements.map((item) => <article class="achievement-item"><p>{item}</p></article>)}
			</div>
		</section>

		<section class="content-section">
			<div class="section-head">
				<p class="section-kicker">Featured Projects</p>
				<h2>Real systems across enterprise delivery, mobile products, and integrations.</h2>
				<p class="section-copy">
					Content-driven project entries power the portfolio structure, making it easy to scale the
					site as more case studies are added.
				</p>
			</div>
			<div class="project-grid">
				{featuredProjects.slice(0, 6).map((project) => <ProjectCard project={project} />)}
			</div>
		</section>

		<section class="content-section">
			<div class="section-head">
				<p class="section-kicker">Published Mobile Apps</p>
				<h2>Built and published educational apps used by hundreds of thousands of users.</h2>
			</div>
			<div class="apps-grid">
				{
					publishedApps.map((app) => (
						<article class="app-card">
							<div class="app-card-top">
								<div>
									<p class="project-label">Published App</p>
									<h3>{app.name}</h3>
								</div>
								<p class="app-downloads">{app.downloads}</p>
							</div>
							<p>{app.purpose}</p>
							<p>{app.impact}</p>
							<p class="app-tech">{app.tech}</p>
							<a class="button button-secondary app-link" href={app.link} target="_blank" rel="noreferrer">
								View on Play Store
							</a>
						</article>
					))
				}
			</div>
		</section>

		<section class="content-section">
			<div class="section-head">
				<p class="section-kicker">Skills</p>
				<h2>Clear strengths across mobile engineering, frontend systems, and backend architecture.</h2>
			</div>
			<div class="skills-grid">
				{
					skillGroups.map((group) => (
						<article class="skill-card">
							<p class="skill-title">{group.title}</p>
							<p class="skill-copy">{group.description}</p>
							<div class="skill-list">
								{group.items.map((item) => <span class="skill-chip">{item}</span>)}
							</div>
						</article>
					))
				}
			</div>
		</section>
	</main>
</Layout>
