---
import { site } from '../data/site';

const pathname = Astro.url.pathname;
---

<header class="site-header">
	<div class="shell header-inner">
		<a class="brand" href="/">
			<span class="brand-mark">JR</span>
			<span class="brand-copy">
				<strong>{site.name}</strong>
				<span>{site.role}</span>
			</span>
		</a>
		<nav class="site-nav" aria-label="Primary">
			{
				site.navigation.map((item) => (
					<a class:list={['nav-link', pathname === item.href && 'is-active']} href={item.href}>
						{item.label}
					</a>
				))
			}
		</nav>
		<button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle theme">
			<span class="theme-toggle-dot" aria-hidden="true"></span>
			<span class="theme-toggle-label" data-theme-label>Light</span>
		</button>
	</div>
</header>
